// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "./generated/zod" // Destination for your zod schemas
}

enum Gender {
  Male
  Female
}

enum PaymentStatus {
  Pending
  Success
  Failure
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  password  String // Stored as a hashed string
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userRoles UserRole[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String
  permissions Permission[]
  userRoles   UserRole[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Module {
  id          Int          @id @default(autoincrement())
  name        String
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        Int        @id @default(autoincrement())
  module_id Int
  module    Module     @relation(fields: [module_id], references: [id])
  role_id   Int
  role      Role       @relation(fields: [role_id], references: [id])
  read      Boolean
  write     Boolean
  update    Boolean
  delete    Boolean
  userRoles UserRole[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model UserRole {
  id           Int         @id @default(autoincrement())
  user_id      Int
  user         User        @relation(fields: [user_id], references: [id])
  role_id      Int
  role         Role        @relation(fields: [role_id], references: [id])
  permission   Permission? @relation(fields: [permissionId], references: [id])
  permissionId Int?
}

model Tournament {
  id                      Int                      @id @default(autoincrement())
  name                    String
  description             String
  sportType               String
  startDate               DateTime
  endDate                 DateTime
  location                String
  status                  Boolean
  maxTeams                Int
  entryFee                Int
  prizePool               Int
  banner                  String
  rules                   String
  tournamentRegistrations TournamentRegistration[]
}

model Season {
  id         Int      @id @default(autoincrement())
  seasonName String
  year       Int
  startDate  DateTime
  endDate    DateTime
}

model Player {
  id           Int      @id @default(autoincrement())
  name         String
  dob          DateTime
  gender       Gender
  country      String
  position     Int
  jerseyNumber Int
  height       Int
  weight       Int
  teams        Team[]
}

model Team {
  id                      Int                      @id @default(autoincrement())
  name                    String
  logo                    String
  captain_id              Int
  captain                 Player                   @relation(fields: [captain_id], references: [id])
  coachName               String
  homeGround              Boolean
  tournamentRegistrations TournamentRegistration[]
}

model TournamentRegistration {
  id            Int           @id @default(autoincrement())
  team_id       Int
  team          Team          @relation(fields: [team_id], references: [id])
  tournament_id Int
  tournament    Tournament    @relation(fields: [tournament_id], references: [id])
  status        Boolean
  paymentStatus PaymentStatus
}
